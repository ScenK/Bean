{
  "name": "bean",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run build --filter=@bean/core && pnpm --filter @bean/app build && pnpm --filter @bean/app dev",
    "dist:mac": "turbo run build --filter=@bean/core --filter=@bean/discord --filter=@bean/teams && pnpm --filter @bean/app dist:mac",
    "release": "pnpm --dir packages/app version",
    "worktree:create": "bash scripts/worktree.sh create",
    "worktree:remove": "bash scripts/worktree.sh remove",
    "upgrade:outdated": "node scripts/outdated-report.mjs"
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  }
}
