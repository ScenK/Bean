{
  "name": "@bean/app",
  "version": "0.8.9",
  "description": "A desktop companion that chats, remembers, and — with your confirmation — gets things done.",
  "author": "Scen.K",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node scripts/dev.mjs",
    "start": "electron dist/main.js",
    "dist:mac": "pnpm build && electron-builder --mac",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postversion": "git push --follow-tags"
  },
  "build": {
    "appId": "dev.scenk.bean",
    "productName": "Bean",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../.bean",
        "to": "builtin"
      },
      {
        "from": "../discord/dist",
        "to": "chatops/discord",
        "filter": [
          "server.js",
          "server.js.map"
        ]
      },
      {
        "from": "../teams/dist",
        "to": "chatops/teams",
        "filter": [
          "server.js",
          "server.js.map"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "devDependencies": {
    "@bean/core": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "dompurify": "^3.4.11",
    "electron": "latest",
    "electron-builder": "latest",
    "esbuild": "latest",
    "marked": "^18.0.5",
    "preact": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
